<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "KPI Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Apply theme before render to avoid flash -->
    <script>
      if (localStorage.theme === 'dark' || (!localStorage.theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      }
    </script>
  </head>

  <body class="h-full bg-surface text-ink">
    <% if current_user %>
    <div class="flex h-full" data-controller="sidebar">

      <!-- Mobile overlay -->
      <div data-sidebar-target="overlay"
           data-action="click->sidebar#close"
           class="hidden fixed inset-0 z-40 bg-black/50 md:hidden"></div>

      <!-- Sidebar -->
      <aside data-sidebar-target="sidebar"
             class="fixed md:static inset-y-0 left-0 z-50 md:z-auto w-56 flex-shrink-0 bg-sidebar border-r border-stroke flex flex-col -translate-x-full md:translate-x-0 transition-transform duration-200 ease-in-out">
        <div class="px-6 py-5 border-b border-stroke flex items-center justify-between">
          <span class="text-lg font-bold tracking-tight text-ink">KPI Dashboard</span>
          <!-- Close button (mobile only) -->
          <button data-action="click->sidebar#close"
                  class="md:hidden p-1 rounded text-dim hover:text-ink">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-1">
          <%= link_to root_path, class: nav_link_class(root_path), data: { action: "click->sidebar#close" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Overview
          <% end %>
          <%= link_to team_members_path, class: nav_link_class(team_members_path), data: { action: "click->sidebar#close" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Team Members
          <% end %>
          <%= link_to task_types_path, class: nav_link_class(task_types_path), data: { action: "click->sidebar#close" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            KPI Settings
          <% end %>
          <%= link_to users_path, class: nav_link_class(users_path), data: { action: "click->sidebar#close" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Users
          <% end %>
          <% if current_user.admin? %>
            <%= link_to "/jobs", class: nav_link_class("/jobs"), data: { action: "click->sidebar#close" } do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              Job Queue
            <% end %>
          <% end %>
        </nav>

        <div class="px-3 pb-4 space-y-2">
          <div class="px-3 py-2 text-xs text-faint truncate"><%= current_user.name.presence || current_user.email %></div>

          <button data-controller="theme-toggle"
                  data-action="click->theme-toggle#toggle"
                  class="w-full flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-dim hover:text-ink hover:bg-elevated transition-colors">
            <span data-theme-toggle-target="icon">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            </span>
            Toggle theme
          </button>

          <%= form_with url: sync_path, method: :post, local: false do |f| %>
            <%= f.hidden_field :date, value: Date.yesterday.iso8601 %>
            <%= f.submit "Sync Hubstaff",
                class: "w-full flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium bg-accent hover:bg-accent-hi text-white transition-colors cursor-pointer" %>
          <% end %>

          <%= button_to "Sign out", logout_path, method: :delete,
                class: "w-full flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-dim hover:text-ink hover:bg-elevated transition-colors cursor-pointer" %>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col overflow-hidden min-w-0">

        <!-- Mobile top bar -->
        <div class="md:hidden flex items-center gap-3 px-4 py-3 bg-sidebar border-b border-stroke flex-shrink-0">
          <button data-action="click->sidebar#open"
                  class="p-1.5 rounded-lg text-dim hover:text-ink hover:bg-elevated transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <span class="text-base font-bold text-ink"><%= content_for(:title) || "KPI Dashboard" %></span>
        </div>

        <% if notice %>
          <div class="bg-green-50 border-b border-green-200 text-green-700 px-6 py-3 text-sm dark:bg-green-900/50 dark:border-green-700 dark:text-green-300">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="bg-red-50 border-b border-red-200 text-red-700 px-6 py-3 text-sm dark:bg-red-900/50 dark:border-red-700 dark:text-red-300">
            <%= alert %>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto p-4 md:p-6">
          <%= yield %>
        </main>
      </div>
    </div>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
